{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build",
        "-DCMAKE_BUILD_TYPE=${input:buildType}",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "problemMatcher": []
    },
    {
      "label": "CMake: Build selected target",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build",
        "--target",
        "${input:buildTarget}",
        "--config",
        "${input:buildType}"
      ],
      "dependsOn": "CMake: Configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ]
    },
    {
      "label": "CMake: Build all",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build",
        "--config",
        "${input:buildType}"
      ],
      "dependsOn": "CMake: Configure",
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ]
    },
    {
      "label": "CMake: Clean",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build",
        "--target",
        "clean",
        "--config",
        "${input:buildType}"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "buildTarget",
      "type": "pickString",
      "description": "Choose target from CMakeLists.txt",
      "options": [
        "main_window",
        "main_mouse",
        "main_keys",
        "main_platform"
      ],
      "default": "main_window"
    },
    {
      "id": "buildType",
      "type": "pickString",
      "description": "Choose CMake build type/configuration",
      "options": [
        "Debug",
        "Release",
        "RelWithDebInfo",
        "MinSizeRel"
      ],
      "default": "Debug"
    }
  ]
}
